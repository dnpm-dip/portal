{
    "name": "@dnpm-dip/theme",
    "type": "module",
    "version": "2.0.0",
    "description": "DNPM DIP theme for vuecs components, built on top of @vuecs/theme-tailwind.",
    "license": "MIT",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "style": "./src/index.css",
            "import": "./dist/index.mjs"
        },
        "./index.css": "./src/index.css",
        "./src/index.css": "./src/index.css"
    },
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist",
        "src/index.css",
        "src/styles"
    ],
    "scripts": {
        "build": "tsdown"
    },
    "keywords": [
        "dnpm-dip",
        "vuecs",
        "theme",
        "tailwindcss",
        "ui-theme"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "peter.placzek1996@gmail.com",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dnpm-dip/portal.git",
        "directory": "packages/theme"
    },
    "bugs": {
        "url": "https://github.com/dnpm-dip/portal/issues"
    },
    "homepage": "https://github.com/dnpm-dip/portal#readme",
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@authup/client-web-kit-theme": "^1.0.0-beta.54",
        "@vuecs/design": "^1.0.8",
        "@vuecs/theme-tailwind": "^6.1.1"
    },
    "peerDependencies": {
        "@vuecs/core": "^3.x",
        "@vuecs/design": "^1.x",
        "@vuecs/theme-tailwind": "^6.x",
        "tailwindcss": "^4.x"
    }
}
